+// Windows + Bun: process.env.PATH may be undefined (case-sensitive key lookup)
+// while process.env.Path holds the actual value. Normalize so npm ecosystem tools
+// like @npmcli/arborist can find git via which.sync("git").
+if (process.platform === "win32") {
+  if (!process.env.PATH) process.env.PATH = process.env.Path ?? ""
+  const git = which("git")
+  if (git) {
+    const dir = path.dirname(git)
+    if (!process.env.PATH.split(path.delimiter).includes(dir)) process.env.PATH += path.delimiter + dir
+  }
+}
